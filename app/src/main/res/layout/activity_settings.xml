<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_eggs_pattern"
    android:fillViewport="true"
    tools:ignore="TooManyViews">

    <LinearLayout
        android:id="@+id/settings_content_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_gravity="center_horizontal">

        <!-- Заголовок -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="@string/back"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#424242"
                android:paddingStart="16dp"
                android:paddingEnd="20dp" />

            <TextView
                android:id="@+id/tv_settings_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/btn_back"
                android:layout_toStartOf="@id/btn_language"
                android:layout_centerVertical="true"
                android:gravity="center"
                android:text="@string/settings_title"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FF6B35"
                android:translationX="-8dp" />

            <Button
                android:id="@+id/btn_language"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_language_button"
                android:text="@string/language_ru"
                android:textSize="20sp"
                android:padding="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:textAllCaps="false"
                android:includeFontPadding="false"
                android:contentDescription="@string/language" />
        </RelativeLayout>


        <!-- Раздел: Пресеты -->
        <LinearLayout
            android:id="@+id/layout_presets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/preset_title"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/preset_desc"
                android:textSize="12sp"
                android:textColor="#BDBDBD"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <Button
                    android:id="@+id/btn_preset_safe"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/preset_safe"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:gravity="center"
                    android:includeFontPadding="true"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:backgroundTint="#455A64"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/btn_preset_balance"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="@string/preset_balance"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:gravity="center"
                    android:includeFontPadding="true"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:backgroundTint="#546E7A"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/btn_preset_aggressive"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="@string/preset_aggressive"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:gravity="center"
                    android:includeFontPadding="true"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:backgroundTint="#BF360C"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <!-- Раздел: CV режим -->
        <LinearLayout
            android:id="@+id/layout_cv_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cv_mode_title"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cv_mode_desc"
                android:textSize="12sp"
                android:textColor="#BDBDBD"
                android:layout_marginBottom="10dp" />

            <Spinner
                android:id="@+id/spinner_cv_mode"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="#333333" />
        </LinearLayout>


        <!-- Раздел: Авто-фичи (BETA) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_features_title"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FF6B35"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_features_warning"
                android:textSize="12sp"
                android:textColor="#FF9800"
                android:layout_marginBottom="16dp" />

            <!-- Информация об интервале подарков -->
            <TextView
                android:id="@+id/tv_gift_interval_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gift_interval_current"
                android:textSize="12sp"
                android:textColor="#4CAF50"
                android:layout_marginBottom="12dp" />

            <!-- Авто-исследования -->
            <CheckBox
                android:id="@+id/cb_auto_research"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_research"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_auto_research_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_research_desc"
                android:textSize="11sp"
                android:textColor="#888888"
                android:layout_marginStart="32dp"
                android:layout_marginBottom="8dp" />

            <!-- Настройка интервала (активна только когда включены авто-исследования) -->
            <LinearLayout
                android:id="@+id/layout_research_interval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="32dp"
                android:layout_marginBottom="8dp"
                android:enabled="false"
                android:alpha="0.5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_research_interval_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/research_interval"
                        android:textSize="12sp"
                        android:textColor="#CCCCCC" />

                    <EditText
                        android:id="@+id/et_research_interval"
                        style="@style/CompactNumberInput"
                        android:layout_width="60dp"
                        android:inputType="number"
                        android:digits="0123456789"
                        android:hint="@string/research_interval"
                        android:importantForAutofill="no"
                        android:textColor="#FFFFFF"
                        android:textAlignment="center"
                        android:background="#333333" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekbar_research_interval"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:max="300"
                    android:progress="90"
                    android:min="30"
                    tools:ignore="UnusedAttribute" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/research_interval_range"
                    android:textSize="10sp"
                    android:textColor="#666666"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Предупреждение о конфликте таймеров -->
            <TextView
                android:id="@+id/tv_timer_warning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/timer_conflict_warning"
                android:textSize="11sp"
                android:textColor="#FF9800"
                android:layout_marginStart="32dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <!-- Настройка свайпов -->
            <LinearLayout
                android:id="@+id/layout_swipe_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="32dp"
                android:layout_marginBottom="16dp"
                android:enabled="false"
                android:alpha="0.5">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lab_scroll_settings"
                    android:textSize="12sp"
                    android:textColor="#CCCCCC"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/swipes_up"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/et_swipes_up"
                        style="@style/CompactNumberInput"
                        android:layout_width="60dp"
                        android:inputType="number"
                        android:digits="0123456789"
                        android:maxLength="2"
                        android:hint="@string/swipes_up"
                        android:importantForAutofill="no"
                        android:textColor="#FFFFFF"
                        android:textAlignment="center"
                        android:background="#333333" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/swipes_down"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/et_swipes_down"
                        style="@style/CompactNumberInput"
                        android:layout_width="60dp"
                        android:inputType="number"
                        android:digits="0123456789"
                        android:maxLength="2"
                        android:hint="@string/swipes_down"
                        android:importantForAutofill="no"
                        android:textColor="#FFFFFF"
                        android:textAlignment="center"
                        android:background="#333333" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/swipes_hint"
                    android:textSize="10sp"
                    android:textColor="#666666"
                    android:layout_marginTop="4dp" />

                <CheckBox
                    android:id="@+id/cb_research_strict_filter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/research_strict_filter"
                    android:textColor="#CCCCCC"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/research_strict_filter_desc"
                    android:textSize="10sp"
                    android:textColor="#666666"
                    android:layout_marginTop="2dp" />

                <CheckBox
                    android:id="@+id/cb_research_fast_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/research_fast_mode"
                    android:textColor="#CCCCCC"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/research_fast_mode_desc"
                    android:textSize="10sp"
                    android:textColor="#666666"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Авто-буст 2x деньги -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <CheckBox
                    android:id="@+id/cb_auto_boosts"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/auto_boost"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
                    
                <ImageButton
                    android:id="@+id/btn_boost2x_info"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_menu_info_details"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/info"
                    app:tint="#4CAF50" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_auto_boost_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_boost_desc"
                android:textSize="11sp"
                android:textColor="#FF9800"
                android:layout_marginStart="32dp"
                android:layout_marginBottom="4dp" />
                
            <TextView
                android:id="@+id/tv_auto_boost_pause_warning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_boost_pause_warning"
                android:textSize="10sp"
                android:textColor="#AAAAAA"
                android:layout_marginStart="32dp"
                android:layout_marginBottom="8dp" />

            <!-- Настройка интервала авто-буста 2x -->
            <LinearLayout
                android:id="@+id/layout_boost2x_interval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="32dp"
                android:layout_marginBottom="16dp"
                android:enabled="false"
                android:alpha="0.5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_boost2x_interval_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/boost_interval"
                        android:textSize="12sp"
                        android:textColor="#CCCCCC" />

                    <EditText
                        android:id="@+id/et_boost2x_interval"
                        style="@style/CompactNumberInput"
                        android:layout_width="60dp"
                        android:inputType="number"
                        android:digits="0123456789"
                        android:hint="@string/boost_interval"
                        android:importantForAutofill="no"
                        android:textColor="#FFFFFF"
                        android:textAlignment="center"
                        android:background="#333333" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekbar_boost2x_interval"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:max="60"
                    android:progress="55"
                    android:min="1"
                    tools:ignore="UnusedAttribute" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/boost_interval_range"
                    android:textSize="10sp"
                    android:textColor="#666666"
                    android:layout_marginTop="2dp" />
                    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/boost_first_activation"
                    android:textSize="10sp"
                    android:textColor="#888888"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Авто-дроны -->
            <CheckBox
                android:id="@+id/cb_auto_drones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_drones"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_auto_drones_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_drones_desc"
                android:textSize="11sp"
                android:textColor="#FF9800"
                android:layout_marginStart="32dp"
                android:layout_marginBottom="4dp" />
                
            <TextView
                android:id="@+id/tv_auto_drones_conflict"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_drones_conflict"
                android:textSize="10sp"
                android:textColor="#AAAAAA"
                android:layout_marginStart="32dp"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/save"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#4CAF50" />

            <Button
                android:id="@+id/btn_reset"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:gravity="center"
                android:text="@string/reset"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#757575" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>
